# ---------------------------------------------------------------------------
# CareerPilot AI — environment configuration
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# ---- Matcher backend ----
# auto  -> use OpenAI if OPENAI_API_KEY is set, else local model
# local -> force local sentence-transformers (free, offline)
# openai-> force OpenAI embeddings (requires OPENAI_API_KEY)
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Jobs scoring below this relevance (0..1) are dropped.
MATCH_THRESHOLD=0.35

# ---- OpenAI (optional — only needed for OpenAI embeddings or LLM cover letters)
OPENAI_API_KEY=

# ---- Email reporting (optional) ----
# Use a Gmail App Password, NOT your real password:
# https://support.google.com/accounts/answer/185833
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
REPORT_TO_EMAIL=

# ---- Run behavior ----
TOP_K_JOBS=10
AUTO_OPEN_BROWSER=true
